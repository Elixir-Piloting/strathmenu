generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id    String  @id @default(cuid())
  name  String  @unique
  items MenuItem[]
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String
  price       Float
  category    Category @relation(fields: [categoryId], references: [id])
  categoryId  String
  day         String?
  mealPeriod  String?
  location    String?
  imageUrl    String?
  createdAt   DateTime @default(now())
}